"""Hand landmarker with mouse cursor control — Raspberry Pi / Linux version."""

import argparse
import os
import sys
import time

import cv2
import mediapipe as mp
import pyautogui

from mediapipe.tasks import python
from mediapipe.tasks.python import vision


# -----------------------------
# Linux / Raspberry Pi checks
# -----------------------------
if "DISPLAY" not in os.environ:
    sys.exit(
        "ERROR: DISPLAY is not set. Run this from the Raspberry Pi desktop, "
        "not a plain SSH terminal."
    )

pyautogui.FAILSAFE = True
pyautogui.PAUSE = 0

# Global variables
COUNTER = 0
FPS = 0
START_TIME = time.time()
DETECTION_RESULT = None

# Smoothing buffer
SMOOTHING_WINDOW = 7
position_buffer = []


def smooth_position(x, y):
    position_buffer.append((x, y))
    if len(position_buffer) > SMOOTHING_WINDOW:
        position_buffer.pop(0)
    avg_x = int(sum(p[0] for p in position_buffer) / len(position_buffer))
    avg_y = int(sum(p[1] for p in position_buffer) / len(position_buffer))
    return avg_x, avg_y


def clamp(value, low, high):
    return max(low, min(value, high))


def run(
    model: str,
    num_hands: int,
    min_hand_detection_confidence: float,
    min_hand_presence_confidence: float,
    min_tracking_confidence: float,
    camera_id: int,
    width: int,
    height: int,
) -> None:
    global DETECTION_RESULT, COUNTER, FPS, START_TIME

    screen_w, screen_h = pyautogui.size()

    # Open Logitech webcam more reliably on Linux
    cap = cv2.VideoCapture(camera_id, cv2.CAP_V4L2)
    if not cap.isOpened():
        cap = cv2.VideoCapture(camera_id)

    if not cap.isOpened():
        sys.exit(
            f"ERROR: Could not open camera {camera_id}. "
            "Try a different --cameraId such as 0 or 1."
        )

    cap.set(cv2.CAP_PROP_FRAME_WIDTH, width)
    cap.set(cv2.CAP_PROP_FRAME_HEIGHT, height)

    # Optional: request MJPG for better USB webcam performance on Pi
    cap.set(cv2.CAP_PROP_FOURCC, cv2.VideoWriter_fourcc(*"MJPG"))

    # Give camera time to warm up
    time.sleep(1.0)

    row_size = 35
    left_margin = 16
    text_color = (255, 255, 255)
    font_size = 0.7
    font_thickness = 2
    fps_avg_frame_count = 10

    # Tracking state
    was_fist = False
    ily_start_time = None
    tracking_enabled = False
    ILY_HOLD_SECONDS = 2.0

    # Cursor movement tuning
    active_x_min = 0.15
    active_x_max = 0.85
    active_y_min = 0.15
    active_y_max = 0.85

    def save_result(result: vision.HandLandmarkerResult,
                    unused_output_image: mp.Image,
                    timestamp_ms: int):
        global FPS, COUNTER, START_TIME, DETECTION_RESULT

        if COUNTER % fps_avg_frame_count == 0:
            elapsed = time.time() - START_TIME
            if elapsed > 0:
                FPS = fps_avg_frame_count / elapsed
            START_TIME = time.time()

        DETECTION_RESULT = result
        COUNTER += 1

    base_options = python.BaseOptions(model_asset_path=model)
    options = vision.HandLandmarkerOptions(
        base_options=base_options,
        running_mode=vision.RunningMode.LIVE_STREAM,
        num_hands=num_hands,
        min_hand_detection_confidence=min_hand_detection_confidence,
        min_hand_presence_confidence=min_hand_presence_confidence,
        min_tracking_confidence=min_tracking_confidence,
        result_callback=save_result,
    )
    detector = vision.HandLandmarker.create_from_options(options)

    HAND_CONNECTIONS = [
        (0, 1), (1, 2), (2, 3), (3, 4),        # thumb
        (0, 5), (5, 6), (6, 7), (7, 8),        # index
        (0, 9), (9, 10), (10, 11), (11, 12),   # middle
        (0, 13), (13, 14), (14, 15), (15, 16), # ring
        (0, 17), (17, 18), (18, 19), (19, 20), # pinky
        (5, 9), (9, 13), (13, 17)              # palm
    ]

    last_timestamp_ms = 0

    while cap.isOpened():
        success, image = cap.read()
        if not success:
            sys.exit("ERROR: Unable to read from webcam.")

        image = cv2.flip(image, 1)
        rgb_image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)

        mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=rgb_image)

        timestamp_ms = int(time.time() * 1000)
        if timestamp_ms <= last_timestamp_ms:
            timestamp_ms = last_timestamp_ms + 1
        last_timestamp_ms = timestamp_ms

        detector.detect_async(mp_image, timestamp_ms)

        frame_h, frame_w, _ = image.shape

        # FPS text
        cv2.putText(
            image,
            f"FPS: {FPS:.1f}",
            (left_margin, row_size),
            cv2.FONT_HERSHEY_DUPLEX,
            font_size,
            text_color,
            font_thickness,
            cv2.LINE_AA,
        )

        # Active movement box
        box_x1 = int(active_x_min * frame_w)
        box_y1 = int(active_y_min * frame_h)
        box_x2 = int(active_x_max * frame_w)
        box_y2 = int(active_y_max * frame_h)
        cv2.rectangle(image, (box_x1, box_y1), (box_x2, box_y2), (100, 255, 100), 2)

        if DETECTION_RESULT and DETECTION_RESULT.hand_landmarks:
            for idx in range(len(DETECTION_RESULT.hand_landmarks)):
                hand_landmarks = DETECTION_RESULT.hand_landmarks[idx]
                handedness = DETECTION_RESULT.handedness[idx]

                pts = [(int(lm.x * frame_w), int(lm.y * frame_h)) for lm in hand_landmarks]

                # Draw lines
                for a, b in HAND_CONNECTIONS:
                    cv2.line(image, pts[a], pts[b], (200, 200, 200), 2)

                # Draw points
                for pt in pts:
                    cv2.circle(image, pt, 4, (0, 128, 255), -1)

                # Hand label
                x_coords = [lm.x for lm in hand_landmarks]
                y_coords = [lm.y for lm in hand_landmarks]
                text_x = int(min(x_coords) * frame_w)
                text_y = max(20, int(min(y_coords) * frame_h) - 10)

                hand_name = handedness[0].category_name
                cv2.putText(
                    image,
                    hand_name,
                    (text_x, text_y),
                    cv2.FONT_HERSHEY_DUPLEX,
                    0.7,
                    (88, 205, 54),
                    2,
                    cv2.LINE_AA,
                )

                # ILY gesture detection
                # You may need to flip thumb logic depending on left/right hand and mirroring
                thumb_out = hand_landmarks[4].x < hand_landmarks[3].x
                index_out = hand_landmarks[8].y < hand_landmarks[6].y
                middle_in = hand_landmarks[12].y > hand_landmarks[10].y
                ring_in = hand_landmarks[16].y > hand_landmarks[14].y
                pinky_out = hand_landmarks[20].y < hand_landmarks[18].y
                is_ily = thumb_out and index_out and middle_in and ring_in and pinky_out

                if is_ily:
                    if ily_start_time is None:
                        ily_start_time = time.time()

                    elapsed = time.time() - ily_start_time
                    remaining = max(0.0, ILY_HOLD_SECONDS - elapsed)

                    if elapsed >= ILY_HOLD_SECONDS:
                        tracking_enabled = not tracking_enabled
                        ily_start_time = None
                        position_buffer.clear()
                    else:
                        cv2.putText(
                            image,
                            f"ILY hold: {remaining:.1f}s",
                            (left_margin, row_size * 2),
                            cv2.FONT_HERSHEY_DUPLEX,
                            font_size,
                            (255, 100, 255),
                            font_thickness,
                            cv2.LINE_AA,
                        )
                else:
                    ily_start_time = None

                state_text = "TRACKING ON" if tracking_enabled else "TRACKING OFF"
                state_color = (0, 255, 0) if tracking_enabled else (0, 0, 255)
                cv2.putText(
                    image,
                    state_text,
                    (left_margin, row_size * 3),
                    cv2.FONT_HERSHEY_DUPLEX,
                    font_size,
                    state_color,
                    font_thickness,
                    cv2.LINE_AA,
                )

                if not tracking_enabled:
                    continue

                # Use landmark 9 (middle palm area)
                palm = hand_landmarks[9]

                # Map only the center box to the screen
                norm_x = (palm.x - active_x_min) / (active_x_max - active_x_min)
                norm_y = (palm.y - active_y_min) / (active_y_max - active_y_min)

                norm_x = clamp(norm_x, 0.0, 1.0)
                norm_y = clamp(norm_y, 0.0, 1.0)

                raw_x = int(norm_x * screen_w)
                raw_y = int(norm_y * screen_h)

                smooth_x, smooth_y = smooth_position(raw_x, raw_y)
                pyautogui.moveTo(smooth_x, smooth_y, duration=0, _pause=False)

                cursor_x = int(palm.x * frame_w)
                cursor_y = int(palm.y * frame_h)

                # Fist = drag
                fingertips = [8, 12, 16, 20]
                knuckles = [6, 10, 14, 18]
                is_fist = all(
                    hand_landmarks[tip].y > hand_landmarks[knuckle].y
                    for tip, knuckle in zip(fingertips, knuckles)
                )

                if is_fist:
                    cv2.circle(image, (cursor_x, cursor_y), 18, (0, 0, 255), -1)
                    if not was_fist:
                        pyautogui.mouseDown()
                else:
                    cv2.circle(image, (cursor_x, cursor_y), 14, (0, 255, 255), -1)
                    if was_fist:
                        pyautogui.mouseUp()

                was_fist = is_fist

                status = "DRAG" if is_fist else "MOVE"
                cv2.putText(
                    image,
                    status,
                    (left_margin, row_size * 4),
                    cv2.FONT_HERSHEY_DUPLEX,
                    font_size,
                    (0, 0, 255) if is_fist else (0, 200, 0),
                    font_thickness,
                    cv2.LINE_AA,
                )

                # Only use first detected hand
                break

        cv2.imshow("Hand Mouse - Raspberry Pi", image)
        key = cv2.waitKey(1) & 0xFF

        if key == 27 or key == ord("q"):
            break

    if was_fist:
        pyautogui.mouseUp()

    detector.close()
    cap.release()
    cv2.destroyAllWindows()


def main():
    parser = argparse.ArgumentParser(
        formatter_class=argparse.ArgumentDefaultsHelpFormatter
    )
    parser.add_argument("--model", type=str, default="hand_landmarker.task")
    parser.add_argument("--numHands", type=int, default=1)
    parser.add_argument("--minHandDetectionConfidence", type=float, default=0.5)
    parser.add_argument("--minHandPresenceConfidence", type=float, default=0.5)
    parser.add_argument("--minTrackingConfidence", type=float, default=0.5)
    parser.add_argument("--cameraId", type=int, default=0)
    parser.add_argument("--frameWidth", type=int, default=640)
    parser.add_argument("--frameHeight", type=int, default=480)
    args = parser.parse_args()

    run(
        args.model,
        args.numHands,
        args.minHandDetectionConfidence,
        args.minHandPresenceConfidence,
        args.minTrackingConfidence,
        args.cameraId,
        args.frameWidth,
        args.frameHeight,
    )


if __name__ == "__main__":
    main()
